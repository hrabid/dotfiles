#!/usr/bin/env bash
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  wallpaper-switcher.sh
#  Pick a wallpaper with rofi, apply via awww,
#  and regenerate colors with matugen.
#
#  Dependencies: rofi  awww  matugen  libnotify
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ── User Config (override via env) ────────────
WALLPAPER_DIR="${WALLPAPER_DIR:-$HOME/Pictures/wallpapers}"

# awww transition: fade | wipe | grow | outer | wave | random | left | right | top | bottom | center
awww_TRANSITION="${SWWW_TRANSITION:-wipe}"
awww_TRANSITION_DURATION="${SWWW_TRANSITION_DURATION:-1.2}"
awww_TRANSITION_FPS="${SWWW_TRANSITION_FPS:-60}"

CACHE_FILE="${XDG_CACHE_HOME:-$HOME/.cache}/wallpaper-switcher/current"

# ── Helpers ───────────────────────────────────
die() {
  notify-send -u critical "Wallpaper Switcher" "$*" 2>/dev/null
  echo "ERROR: $*" >&2
  exit 1
}
notify() { notify-send -i image-x-generic "Wallpaper Switcher: Wallpaper Changed" "$*" 2>/dev/null; }

# ── Sanity checks ─────────────────────────────
command -v rofi >/dev/null 2>&1 || die "rofi is not installed."
command -v awww >/dev/null 2>&1 || die "swww is not installed."
command -v matugen >/dev/null 2>&1 || die "matugen is not installed."
[[ -d "$WALLPAPER_DIR" ]] || die "Wallpaper dir not found: $WALLPAPER_DIR"

# ── Start awww daemon if not running ──────────
if ! awww query &>/dev/null; then
  awww-daemon &
  sleep 0.5
fi

# ── Gather wallpaper files ────────────────────
mapfile -d '' WALLPAPERS < <(
  find "$WALLPAPER_DIR" \
    \( -iname "*.jpg" -o -iname "*.jpeg" \
    -o -iname "*.png" -o -iname "*.webp" \
    -o -iname "*.gif" -o -iname "*.bmp" \) \
    -not -path "*/.*" \
    -print0 | sort -z
)

[[ ${#WALLPAPERS[@]} -eq 0 ]] && die "No images found in $WALLPAPER_DIR"

# ── Build rofi menu: label + icon thumbnail ───
MENU=""
for wp in "${WALLPAPERS[@]}"; do
  label="${wp#"$WALLPAPER_DIR/"}"
  MENU+="${label}\0icon\x1f${wp}\n"
done

# ── Open rofi picker ──────────────────────────
SELECTED=$(
  printf "%b" "$MENU" | rofi \
    -dmenu \
    -i \
    -p "󰋩  Wallpaper" \
    -show-icons \
    -theme ~/.config/rofi/launchers/type-5/style-2.rasi \
    -format "p"
)

[[ -z "$SELECTED" ]] && exit 0 # user cancelled

WALLPAPER="${WALLPAPER_DIR}/${SELECTED}"
[[ -f "$WALLPAPER" ]] || die "File not found: $WALLPAPER"

# ── Apply wallpaper via awww ──────────────────
awww img "$WALLPAPER" \
  --transition-type "$awww_TRANSITION" \
  --transition-duration "$awww_TRANSITION_DURATION" \
  --transition-fps "$awww_TRANSITION_FPS" \
  --transition-bezier ".43,1.19,1,.4" ||
  die "awww failed to set wallpaper."

# ── Regenerate colors with matugen ───────────
matugen image "$WALLPAPER" \
  --prefer=darkness ||
  die "matugen failed to extract colors."

# ── Cache current wallpaper path ─────────────
mkdir -p "$(dirname "$CACHE_FILE")"
printf '%s\n' "$WALLPAPER" >"$CACHE_FILE"

notify "✔ $(basename "$WALLPAPER")"
echo "Wallpaper set → $WALLPAPER"
